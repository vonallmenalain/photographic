rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userPath() {
      return /databases/$(database)/documents/users/$(request.auth.uid);
    }

    function isAdmin() {
      return signedIn()
        && exists(userPath())
        && get(userPath()).data.role == "admin";
    }

    function isSelf(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function activeAccess(accessId) {
      return signedIn()
        && exists(/databases/$(database)/documents/guardianAccess/$(accessId))
        && get(/databases/$(database)/documents/guardianAccess/$(accessId)).data.uid == request.auth.uid
        && get(/databases/$(database)/documents/guardianAccess/$(accessId)).data.revokedAt == null;
    }

    function childAccess(jobId, childId) {
      return activeAccess(request.auth.uid + "_" + jobId + "_" + childId);
    }

    function classAccess(jobId, classId) {
      return activeAccess(request.auth.uid + "_" + jobId + "_class_" + classId);
    }

    function jobAccess(jobId) {
      return activeAccess(request.auth.uid + "_" + jobId + "_job");
    }

    function childAccessFromList(jobId, childIds) {
      return childIds is list
        && (
          (childIds.size() > 0 && childAccess(jobId, childIds[0]))
          || (childIds.size() > 1 && childAccess(jobId, childIds[1]))
          || (childIds.size() > 2 && childAccess(jobId, childIds[2]))
          || (childIds.size() > 3 && childAccess(jobId, childIds[3]))
          || (childIds.size() > 4 && childAccess(jobId, childIds[4]))
          || (childIds.size() > 5 && childAccess(jobId, childIds[5]))
        );
    }

    function canReadPublishedPhoto() {
      return signedIn()
        && resource.data.status == "published"
        && (
          (resource.data.visibility == "child" && childAccessFromList(resource.data.jobId, resource.data.childIds))
          || (resource.data.visibility == "class" && classAccess(resource.data.jobId, resource.data.classId))
          || (resource.data.visibility == "job" && jobAccess(resource.data.jobId))
        );
    }

    match /users/{uid} {
      allow get: if isSelf(uid) || isAdmin();
      allow list: if isAdmin();
      allow create: if isSelf(uid)
        && request.resource.data.role == "guardian"
        && request.resource.data.keys().hasOnly(["email", "role", "createdAt", "lastLoginAt"]);
      allow update: if isAdmin()
        || (
          isSelf(uid)
          && request.resource.data.role == resource.data.role
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["email", "lastLoginAt"])
        );
      allow delete: if isAdmin();
    }

    match /organizations/{orgId} {
      allow read, write: if isAdmin();
    }

    match /jobs/{jobId} {
      allow read: if isAdmin() || jobAccess(jobId);
      allow write: if isAdmin();
    }

    match /classes/{classId} {
      allow read: if isAdmin()
        || classAccess(resource.data.jobId, classId)
        || jobAccess(resource.data.jobId);
      allow write: if isAdmin();
    }

    match /children/{childId} {
      allow read, write: if isAdmin();
    }

    match /accessCodes/{accessCodeId} {
      allow read, write: if isAdmin();
    }

    match /guardianAccess/{accessId} {
      allow get, list: if isAdmin()
        || (signedIn() && resource.data.uid == request.auth.uid);
      allow create, update, delete: if isAdmin();
    }

    match /photos/{photoId} {
      allow read: if isAdmin() || canReadPublishedPhoto();
      allow write: if isAdmin();
    }

    match /orders/{orderId} {
      allow read: if isAdmin()
        || (signedIn() && resource.data.uid == request.auth.uid);
      allow create: if signedIn()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.currency == "CHF"
        && request.resource.data.status in ["draft", "pending"];
      allow update: if isAdmin()
        || (
          signedIn()
          && resource.data.uid == request.auth.uid
          && request.resource.data.uid == resource.data.uid
          && request.resource.data.currency == "CHF"
          && request.resource.data.status in ["draft", "pending", "cancelled"]
        );
      allow delete: if isAdmin();
    }

    match /auditLogs/{logId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
