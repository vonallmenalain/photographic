rules_version = '2';

// ---------------------------------------------------------------------------
// Security model
// ---------------------------------------------------------------------------
// All application data is read and written exclusively by the backend using the
// Firebase Admin SDK, which BYPASSES these rules. The browser never talks to
// Firestore directly – it only uses Firebase Authentication (e-mail sign-in)
// and then calls the backend API.
//
// Therefore the safest rule is to DENY every direct client request. This keeps
// children's photos and parent data fully protected even though the database is
// hosted in the cloud. Do NOT loosen these rules unless you intentionally start
// reading/writing Firestore from the browser.
// ---------------------------------------------------------------------------
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
