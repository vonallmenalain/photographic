# ============================================================================
# Backend-Konfiguration (läuft als Docker-Container auf dem QNAP)
# Kopiere diese Datei nach .env und passe die Werte an.
# ============================================================================

NODE_ENV=production
PORT=4000

# --- Frontend / CORS --------------------------------------------------------
# Die öffentliche Adresse deiner Netlify-App (ohne Slash am Ende).
PUBLIC_APP_URL=https://deine-app.netlify.app
# Optional weitere erlaubte Origins (Komma-getrennt), z. B. Preview-Deploys.
EXTRA_CORS_ORIGINS=

# --- Speicherort (QNAP-Volume im Container) ---------------------------------
STORAGE_DIR=/data/storage
DB_PATH=/data/app.db

# --- Sicherheits-Secrets (UNBEDINGT eigene, lange Zufallswerte setzen!) -----
# Erzeuge z. B. mit:  openssl rand -base64 48
JWT_SECRET=
FILE_TOKEN_SECRET=

# --- Admin-Zugang -----------------------------------------------------------
ADMIN_USERNAME=admin
# Empfohlen: bcrypt-Hash via "npm run create-admin -- <user> <passwort>" erzeugen.
ADMIN_PASSWORD_HASH=
# Nur für ersten Start / lokal: Klartext-Passwort (wird beim Start gehasht).
ADMIN_PASSWORD=

# --- Cookies (Netlify-Frontend + Cloudflare-Tunnel-API = Cross-Site) --------
COOKIE_SECURE=true
COOKIE_SAMESITE=none
# Optional: gemeinsame Domain, falls Frontend & API unter *.deinedomain.de laufen.
COOKIE_DOMAIN=

# --- E-Mail-Versand (SMTP) --------------------------------------------------
# Ohne SMTP_HOST werden Codes/Links nur in die Server-Logs geschrieben (Dev).
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=Foto-Galerie <no-reply@deinedomain.de>
SUPPORT_EMAIL=support@deinedomain.de

# --- Verifizierung & Sessions -----------------------------------------------
VERIFICATION_CODE_TTL_MINUTES=20
VERIFICATION_MAX_ATTEMPTS=6
PARENT_SESSION_TTL_DAYS=30

# --- Aufbewahrung der Galerien (Tage) ---------------------------------------
GALLERY_RETENTION_DAYS=30

# --- Bildvarianten ----------------------------------------------------------
IMG_PREVIEW_MAX=1100
IMG_PREVIEW_QUALITY=62
IMG_THUMB_MAX=520
IMG_THUMB_QUALITY=58
IMG_WATERMARK_TEXT=VORSCHAU · GESCHÜTZT

# --- Upload-Limit (MB pro Datei) --------------------------------------------
MAX_UPLOAD_MB=60

# --- Stripe (optional) ------------------------------------------------------
# Leer lassen für manuellen Test-Bezahlfluss.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
CURRENCY=eur
