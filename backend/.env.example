# ============================================================================
# Backend-Konfiguration (läuft als Docker-Container auf dem QNAP)
# Kopiere diese Datei nach .env und passe die Werte an.
# ============================================================================

NODE_ENV=production
PORT=4000

# --- Frontend / CORS --------------------------------------------------------
# Die öffentliche Adresse deiner App = eigene Domain (ohne Slash am Ende).
PUBLIC_APP_URL=https://fotos.alae.app
# Weitere erlaubte Origins (Komma-getrennt): rohe Netlify-URL + Preview-Deploys.
EXTRA_CORS_ORIGINS=https://creartphotographic.netlify.app

# --- Speicherort der Fotos (QNAP-Volume im Container) -----------------------
# Nur die Original-Fotos + erzeugte Varianten liegen hier. Alle Metadaten,
# Nutzer, Bestellungen usw. liegen in Cloud Firestore.
STORAGE_DIR=/data/storage

# --- Firebase / Firestore (Datenbank) + Firebase Authentication -------------
# Das Backend nutzt das Firebase Admin SDK und braucht einen Service-Account
# (NICHT die oeffentliche Web-Config). Erstelle ihn in der Firebase Console
# unter "Projekteinstellungen > Dienstkonten > Neuen privaten Schluessel".
# Stelle ihn dem Backend auf EINE dieser Arten bereit:
#   1) FIREBASE_SERVICE_ACCOUNT_PATH = Pfad zur JSON-Datei (empfohlen, Docker)
#   2) FIREBASE_SERVICE_ACCOUNT      = der komplette JSON-Inhalt als String
#   3) GOOGLE_APPLICATION_CREDENTIALS = Standard-ADC-Pfad
FIREBASE_PROJECT_ID=photographic-7ba68
FIREBASE_STORAGE_BUCKET=photographic-7ba68.firebasestorage.app
FIREBASE_SERVICE_ACCOUNT_PATH=/run/secrets/firebase-service-account.json
# FIREBASE_SERVICE_ACCOUNT=
# Parent-Login per Firebase Authentication (E-Mail-Link). true = empfohlen.
FIREBASE_PARENT_AUTH=true

# --- Lokale Entwicklung mit der Firebase Emulator Suite ---------------------
# Wenn gesetzt, spricht das Backend die lokalen Emulatoren an (kein Service-
# Account noetig).  Starten:  npx firebase-tools emulators:start
# FIRESTORE_EMULATOR_HOST=127.0.0.1:8080
# FIREBASE_AUTH_EMULATOR_HOST=127.0.0.1:9099

# --- Sicherheits-Secrets (UNBEDINGT eigene, lange Zufallswerte setzen!) -----
# Erzeuge z. B. mit:  openssl rand -base64 48
JWT_SECRET=
FILE_TOKEN_SECRET=

# --- Admin-Zugang -----------------------------------------------------------
ADMIN_USERNAME=admin
# Empfohlen: bcrypt-Hash via "npm run create-admin -- <user> <passwort>" erzeugen.
ADMIN_PASSWORD_HASH=
# Nur für ersten Start / lokal: Klartext-Passwort (wird beim Start gehasht).
ADMIN_PASSWORD=

# --- Cookies ----------------------------------------------------------------
# Empfohlen: API unter api.alae.app betreiben. Dann liegen Frontend
# (fotos.alae.app) und API (api.alae.app) unter derselben Hauptdomain alae.app
# ("same-site") -> SameSite=lax genuegt und Cookies werden zuverlaessig gesetzt.
COOKIE_SECURE=true
COOKIE_SAMESITE=lax
COOKIE_DOMAIN=.alae.app
# Liegt die API auf einer anderen Domain (echtes Cross-Site), nutze stattdessen:
#   COOKIE_SAMESITE=none
#   COOKIE_DOMAIN=        (leer lassen)

# --- E-Mail-Versand (SMTP) --------------------------------------------------
# Ohne SMTP_HOST werden Codes/Links nur in die Server-Logs geschrieben (Dev).
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=Foto-Galerie <no-reply@alae.app>
SUPPORT_EMAIL=support@alae.app

# --- Verifizierung & Sessions -----------------------------------------------
VERIFICATION_CODE_TTL_MINUTES=20
VERIFICATION_MAX_ATTEMPTS=6
PARENT_SESSION_TTL_DAYS=30

# --- Aufbewahrung der Galerien (Tage) ---------------------------------------
GALLERY_RETENTION_DAYS=30

# --- Bildvarianten ----------------------------------------------------------
IMG_PREVIEW_MAX=1100
IMG_PREVIEW_QUALITY=62
IMG_THUMB_MAX=520
IMG_THUMB_QUALITY=58
IMG_WATERMARK_TEXT=VORSCHAU · GESCHÜTZT

# --- Upload-Limit (MB pro Datei) --------------------------------------------
MAX_UPLOAD_MB=60

# --- Stripe (optional) ------------------------------------------------------
# Leer lassen für manuellen Test-Bezahlfluss.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
CURRENCY=eur
