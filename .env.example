# ============================================================================
# Zentrale Konfiguration für docker-compose (QNAP).
# Kopiere diese Datei nach .env:   cp .env.example .env
# und trage deine Werte ein. Diese Datei wird vom "backend"-Container gelesen.
# ============================================================================

# --- Frontend (Netlify) -----------------------------------------------------
# Oeffentliche Adresse der App (eigene Domain), ohne Slash am Ende.
PUBLIC_APP_URL=https://photographic.alae.app
# Weitere erlaubte Origins (Komma-getrennt), z. B. die rohe Netlify-URL und
# Preview-Deploys. So funktioniert die API auch, wenn jemand creart... direkt aufruft.
EXTRA_CORS_ORIGINS=https://creartphotographic.netlify.app

# --- Firebase (Datenbank = Firestore, Auth = Firebase Authentication) -------
# Siehe docs/08-firebase.md. Das Backend nutzt das Admin SDK und braucht einen
# Service-Account (NICHT die Web-Config). Lege die Datei als
# firebase-service-account.json neben diese .env (wird per Volume eingehängt).
FIREBASE_PROJECT_ID=photographic-7ba68
FIREBASE_STORAGE_BUCKET=photographic-7ba68.firebasestorage.app
# Parent-Login per Firebase Authentication (E-Mail-Link).
#   true  = Eltern erhalten den Firebase-Anmeldelink (Mail von firebaseapp.com).
#   false = Die App verschickt ihre eigene deutsche Mail (Code + Link) per SMTP.
# WICHTIG: Muss zum Frontend-Flag VITE_FIREBASE_PARENT_AUTH passen. Bei false
# unbedingt SMTP unten konfigurieren (siehe docs/04-email-smtp.md).
FIREBASE_PARENT_AUTH=true

# --- Sicherheits-Secrets (eigene Zufallswerte!) -----------------------------
# Erzeugen z. B. mit:  openssl rand -base64 48
JWT_SECRET=
FILE_TOKEN_SECRET=

# --- Admin-Zugang -----------------------------------------------------------
# WICHTIG: ADMIN_PASSWORD / ADMIN_PASSWORD_HASH dienen nur dem ERSTEN Start
# (Seed), solange noch kein Admin in Firestore existiert. Ein danach im
# Adminbereich (Konto → „Passwort ändern“) oder per „Passwort vergessen“
# gesetztes Passwort wird in Firestore gespeichert und überlebt jeden
# Neustart/Deploy – die .env-Werte überschreiben es NICHT mehr.
ADMIN_USERNAME=admin
# Empfohlen: bcrypt-Hash (siehe README, "Admin anlegen"). Beim ersten Start
# kannst du alternativ ADMIN_PASSWORD setzen (wird automatisch gehasht).
ADMIN_PASSWORD_HASH=
ADMIN_PASSWORD=
# Notfall/Wiederherstellung bei Aussperrung: Auf "true" setzen, einmal neu
# starten – dann wird das Passwort des Admins ADMIN_USERNAME aus
# ADMIN_PASSWORD/ADMIN_PASSWORD_HASH erzwungen. Danach UNBEDINGT wieder auf
# "false" stellen, damit ein selbst gesetztes Passwort wieder bestehen bleibt.
ADMIN_PASSWORD_RESET_ON_BOOT=false

# --- Cookies ----------------------------------------------------------------
# Liegen Frontend (photographic.alae.app) und API (api.alae.app) unter derselben
# Hauptdomain alae.app, ist das "same-site": dann reicht SameSite=lax und du
# setzt COOKIE_DOMAIN=.alae.app. Liegt die API auf einer anderen Domain, nutze
# COOKIE_SAMESITE=none und lass COOKIE_DOMAIN leer.
COOKIE_SECURE=true
COOKIE_SAMESITE=lax
COOKIE_DOMAIN=.alae.app

# --- E-Mail-Versand (SMTP) --------------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=Foto-Galerie <no-reply@alae.app>
SUPPORT_EMAIL=support@alae.app
# Zeitlimit (ms) fuer SMTP-Verbindung/Antwort (Standard: 10000).
SMTP_TIMEOUT_MS=10000

# --- Aufbewahrung & Verifizierung -------------------------------------------
GALLERY_RETENTION_DAYS=30
VERIFICATION_CODE_TTL_MINUTES=20
PARENT_SESSION_TTL_DAYS=30

# --- Upload-Limit (MB pro Datei) --------------------------------------------
MAX_UPLOAD_MB=60

# --- Stripe (optional; leer = manueller Test-Bezahlfluss) -------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
CURRENCY=chf
# Welche Zahlungsarten die Stripe-Checkout-Seite anbietet (Komma-getrennt).
# Standard: Karte, TWINT, Apple Pay und Google Pay.
# Hinweis: Apple Pay und Google Pay sind "Wallets" der Methode "card" – Stripe
# blendet sie automatisch ein, sobald sie im Dashboard aktiviert sind und das
# Geraet/der Browser sie unterstuetzt. Sie sind KEINE eigenen payment_method_types;
# "apple_pay"/"google_pay" in dieser Liste werden daher auf "card" abgebildet.
# TWINT funktioniert nur mit CURRENCY=chf.
# Leer lassen, um stattdessen die im Stripe-Dashboard aktivierten Methoden zu nutzen.
STRIPE_PAYMENT_METHODS=card,twint,apple_pay,google_pay

# --- Cloudflare Tunnel (nur falls Tunnel-Container genutzt wird) ------------
CLOUDFLARE_TUNNEL_TOKEN=

# --- Auto-Deploy (Backend-Image + Watchtower) -------------------------------
# Welches Backend-Image gestartet wird. Standard = fertiges Image aus der
# GitHub Container Registry (wird von GitHub Actions automatisch gebaut).
# Nur ändern, wenn du z. B. einen anderen Owner/Tag nutzt (z. B. :sha-<commit>).
# BACKEND_IMAGE=ghcr.io/vonallmenalain/photographic-backend:latest
# Wie oft Watchtower nach einem neueren Image sucht (Sekunden). Standard: 300.
WATCHTOWER_POLL_INTERVAL=300

# Hinweis: STORAGE_DIR/DB_PATH werden in docker-compose.yml gesetzt. Eine lokale
# SQLite-Datei gibt es nicht mehr – alle Daten liegen in Cloud Firestore.
