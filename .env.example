# Frontend Firebase config
VITE_FIREBASE_API_KEY=your-web-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:0000000000000000000000

# Firebase Admin for Netlify Functions
# Use either FIREBASE_SERVICE_ACCOUNT_BASE64 or the three explicit values below.
FIREBASE_SERVICE_ACCOUNT_BASE64=
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Access code hashing
ACCESS_CODE_PEPPER=replace-with-a-long-random-secret
ACCESS_CODE_ONE_TIME=true
ACCESS_CODE_EXPIRES_DAYS=60

# Cloudflare R2 private bucket
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_BUCKET_NAME=your-private-r2-bucket
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_ENDPOINT=
ALLOW_ORIGINAL_UPLOADS=true

# Optional local seed helper
SEED_ADMIN_UID=
