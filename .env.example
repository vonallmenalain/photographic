# ============================================================================
# Zentrale Konfiguration für docker-compose (QNAP).
# Kopiere diese Datei nach .env:   cp .env.example .env
# und trage deine Werte ein. Diese Datei wird vom "backend"-Container gelesen.
# ============================================================================

# --- Frontend (Netlify) -----------------------------------------------------
PUBLIC_APP_URL=https://deine-app.netlify.app
EXTRA_CORS_ORIGINS=

# --- Sicherheits-Secrets (eigene Zufallswerte!) -----------------------------
# Erzeugen z. B. mit:  openssl rand -base64 48
JWT_SECRET=
FILE_TOKEN_SECRET=

# --- Admin-Zugang -----------------------------------------------------------
ADMIN_USERNAME=admin
# Empfohlen: bcrypt-Hash (siehe README, "Admin anlegen"). Beim ersten Start
# kannst du alternativ ADMIN_PASSWORD setzen (wird automatisch gehasht).
ADMIN_PASSWORD_HASH=
ADMIN_PASSWORD=

# --- Cookies (Netlify + Cloudflare Tunnel = unterschiedliche Domains) -------
COOKIE_SECURE=true
COOKIE_SAMESITE=none
COOKIE_DOMAIN=

# --- E-Mail-Versand (SMTP) --------------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=Foto-Galerie <no-reply@deinedomain.de>
SUPPORT_EMAIL=support@deinedomain.de

# --- Aufbewahrung & Verifizierung -------------------------------------------
GALLERY_RETENTION_DAYS=30
VERIFICATION_CODE_TTL_MINUTES=20
PARENT_SESSION_TTL_DAYS=30

# --- Upload-Limit (MB pro Datei) --------------------------------------------
MAX_UPLOAD_MB=60

# --- Stripe (optional; leer = manueller Test-Bezahlfluss) -------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
CURRENCY=eur

# --- Cloudflare Tunnel (nur falls Tunnel-Container genutzt wird) ------------
CLOUDFLARE_TUNNEL_TOKEN=
