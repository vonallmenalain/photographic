# Adresse deiner Backend-API (Cloudflare-Tunnel-Hostname, ohne Slash am Ende).
# Empfohlen: api.alae.app (gleiche Hauptdomain wie das Frontend fotos.alae.app).
# Lokal: http://localhost:4000
VITE_API_BASE_URL=https://api.alae.app

# --- Eltern-Login: Firebase ODER eigener Mail-Versand -----------------------
# true  (Standard) = Eltern melden sich per Firebase-E-Mail-Link an. Die Mail
#                    kommt dann von noreply@...firebaseapp.com (Englisch, oft
#                    Spam).
# false            = Die App verschickt stattdessen ihre EIGENE, deutsche Mail
#                    (6-stelliger Code + Ein-Klick-Link) ueber deinen SMTP-
#                    Server. Empfohlen fuer einen seriösen Absender + bessere
#                    Zustellbarkeit. Muss zum Backend-Flag FIREBASE_PARENT_AUTH
#                    passen (dort ebenfalls auf false setzen).
VITE_FIREBASE_PARENT_AUTH=true

# --- Firebase Web-Konfiguration (fuer Firebase Authentication) --------------
# Findest du in der Firebase Console unter "Projekteinstellungen > Allgemein >
# Deine Apps > Web-App > SDK-Konfiguration". Diese Werte sind oeffentlich.
# Sind sie nicht gesetzt, nutzt die App die fest hinterlegten Projekt-Defaults.
# Hinweis: Diese Werte werden weiterhin fuer den Firestore-Datenbankzugriff
# benoetigt - leer lassen reicht NICHT, um den Firebase-Login abzuschalten.
# Dafuer ist VITE_FIREBASE_PARENT_AUTH=false zustaendig (siehe oben).
VITE_FIREBASE_API_KEY=AIzaSyDghVtwu3VI8BuZCE9wcOghlp9aL_3u428
VITE_FIREBASE_AUTH_DOMAIN=photographic-7ba68.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=photographic-7ba68
VITE_FIREBASE_STORAGE_BUCKET=photographic-7ba68.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=83987903614
VITE_FIREBASE_APP_ID=1:83987903614:web:f5fd8aadc4638eec87942f
